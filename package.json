{
  "name": "agent-catalog-proto",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Catalog prototype for Red Hat OpenShift AI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "tsx src/server/index.ts",
    "dev:all": "npm run server & npm run dev",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,css}' 'tests/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json,css}' 'tests/**/*.{ts,tsx}'",
    "prepare": "husky"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@patternfly/chatbot": "^6.3.0",
    "@patternfly/react-core": "^6.3.0",
    "@patternfly/react-icons": "^6.3.0",
    "@patternfly/react-styles": "^6.3.0",
    "@patternfly/react-table": "^6.5.1",
    "express": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.28.0",
    "@types/express": "^5.0.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^8.0.16",
    "vitest": "^3.2.3"
  }
}
